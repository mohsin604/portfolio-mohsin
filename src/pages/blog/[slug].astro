---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{post.data.title} - Mohsin Shahid</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <article style="padding: 100px 20px; max-width: 800px; margin: 0 auto;">
    <img src={post.data.featuredImage} alt={post.data.title} style="width: 100%; border-radius: 10px;" />
    <span style="color: #f5a623; font-size: 12px; text-transform: uppercase; display: block; margin-top: 20px;">{post.data.category}</span>
    <h1 style="margin: 10px 0;">{post.data.title}</h1>
    <div style="margin-top: 30px; line-height: 1.8;">
      <Content />
    </div>
    <a href="/blog" style="display: inline-block; margin-top: 40px; color: #f5a623;">← Back to Blog</a>
  </article>
</body>
</html>