---
import { getCollection } from 'astro:content';
const posts = await getCollection('blog');
posts.sort((a, b) => new Date(b.data.date) - new Date(a.data.date));
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Blog - Mohsin Shahid</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <section style="padding: 100px 20px; max-width: 1200px; margin: 0 auto;">
    <h1>Blog</h1>
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; margin-top: 40px;">
      {posts.map(post => (
        <div style="border: 1px solid #333; border-radius: 10px; overflow: hidden;">
          <img src={post.data.featuredImage} alt={post.data.title} style="width: 100%; height: 200px; object-fit: cover;" />
          <div style="padding: 20px;">
            <span style="color: #f5a623; font-size: 12px; text-transform: uppercase;">{post.data.category}</span>
            <h2 style="font-size: 18px; margin: 10px 0;">{post.data.title}</h2>
            <p style="font-size: 14px; opacity: 0.7;">{post.data.excerpt}</p>
            <a href={`/blog/${post.id.replace(/\.md$/, '')}`} style="display: inline-block; margin-top: 15px; color: #f5a623;">Read More →</a>
          </div>
        </div>
      ))}
    </div>
  </section>
</body>
</html>