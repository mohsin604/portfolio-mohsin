---
import { getCollection } from 'astro:content';
const posts = await getCollection('blog');
posts.sort((a, b) => new Date(b.data.date) - new Date(a.data.date));
---


<!DOCTYPE html>
<!--[if IE 8]><html class="ie" xmlns="http://www.w3.org/1999/xhtml" xml:lang="en-US" lang="en-US"> <![endif]-->
<!--[if (gte IE 9)|!(IE)]><!-->
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en-US" lang="en-US">
<!--<![endif]-->

<head>
    <!-- Basic Page Needs -->
    <meta charset="utf-8">
    <!--[if IE ]><meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1"/><![endif]-->
    <title>Blog - Mohsin Shahid</title>

    <meta name="author" content="themesflat.com">

    <!-- Mobile Specific Metas -->
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">

    <!--  Style -->
    <link rel="stylesheet" type="text/css" href="/css/bootstrap.css">
    <link rel="stylesheet" type="text/css" href="/css/odometer.min.css">
    <link rel="stylesheet" type="text/css" href="/css/swiper-bundle.min.css">
    <link rel="stylesheet" type="text/css" href="/css/animateText.css">
    <link rel="stylesheet" type="text/css" href="/css/jquery.fancybox.min.css">
    <link rel="stylesheet" type="text/css" href="/css/styles.css">
    <link rel="stylesheet" type="text/css" href="/css/blog.css">

    <!-- Font -->
    <link rel="stylesheet" href="/font/fonts.css">

    <!-- Icon -->
    <link rel="stylesheet" type="text/css" href="/icons/icomoon/style.css">

    <!-- Favicon and Touch Icons  -->
    <link rel="shortcut icon" href="/images/logo/favicon.png">
    <link rel="apple-touch-icon-precomposed" href="/images/logo/favicon.png">
</head>

<body>
    <!-- wrapper -->
    <div id="wrapper" class="bg_dark counter-scroll">

        <div class="body-overlay d-block">
            <div class="bg-shape"></div>
        </div>

        <div class="header d-md-none">
            <div class="header-sidebar style-vertical  bs-light-mode">
                <div class="box">
                    <div class="avatar">
                        <img src="/images/user/mohsin.png" width="68" height="68" alt="avatar">
                    </div>
                    <div class="info">
                        <h6 class="font-4 mb_4">Mohsin Shahid</h6>
                        <div class="text-label text-uppercase fw-6 text_primary-color font-3  letter-spacing-1">
                            WordPress, Shopify &amp; PHP/JS
                            Developer</div>
                    </div>
                </div>
                <ul class="nav-menu style-2 list-icon ">
                    <li>
                        <a class="nav_link" href="/#about">
                            <i class="icon icon-User"></i>
                            <span class="tooltip text-caption-1">About</span>
                        </a>
                    </li>
                    <li>
                        <a class="nav_link" href="/#resume">
                            <i class="icon icon-ReadCvLogo"></i>
                            <span class="tooltip text-caption-1">Resume</span>
                        </a>
                    </li>
                    <li>
                        <a class="nav_link" href="/#services">
                            <i class="icon icon-GearFine"></i>
                            <span class="tooltip text-caption-1">Services</span>
                        </a>
                    </li>
                    <li>
                        <a class="nav_link" href="/#portfolio">
                            <i class="icon icon-Briefcase"></i>
                            <span class="tooltip text-caption-1">Portfolio</span>
                        </a>
                    </li>
                    <li>
                        <a class="nav_link" href="/#pricing">
                            <i class="icon icon-Tag"></i>
                            <span class="tooltip text-caption-1">Pricing</span>
                        </a>
                    </li>
                    <li>
                        <a class="nav_link active" href="/blog">
                            <i class="icon icon-Notebook"></i>
                            <span class="tooltip text-caption-1">Blog</span>
                        </a>
                    </li>
                    <li>
                        <a class="nav_link" href="/#contact">
                            <i class="icon icon-PaperPlaneTilt"></i>
                            <span class="tooltip text-caption-1">Contact</span>
                        </a>
                    </li>
                </ul>
                <a class="menu-button show-menu-mobile  d-sm-none link-no-action" data-target="#menu-2" href="#"><i
                        class="icon-CirclesFour"></i></a>
                <div id="menu-2" class="popup-menu-mobile">
                    <ul class="nav-menu style-3 ">
                        <li class="text-menu text_white">
                            <a href="/"
                                class="nav_link toggle splitting link link-no-action text-button font-3 fw-6">
                                <span class="text" data-splitting>Home</span>
                                <span class="text" data-splitting>Home</span>
                            </a>
                        </li>
                        <li class="text-menu text_white">
                            <a href="/#about"
                                class="nav_link toggle splitting link link-no-action text-button font-3 fw-6">
                                <span class="text" data-splitting>About</span>
                                <span class="text" data-splitting>About</span>
                            </a>
                        </li>
                        <li class="text-menu text_white">
                            <a href="/#resume"
                                class="nav_link toggle splitting link link-no-action text-button font-3 fw-6">
                                <span class="text" data-splitting>Resume</span>
                                <span class="text" data-splitting>Resume</span>
                            </a>
                        </li>
                        <li class="text-menu text_white">
                            <a href="/#services"
                                class="nav_link toggle splitting link link-no-action text-button font-3 fw-6">
                                <span class="text" data-splitting>Services</span>
                                <span class="text" data-splitting>Services</span>
                            </a>
                        </li>
                        <li class="text-menu text_white">
                            <a href="/#portfolio"
                                class="nav_link toggle splitting link link-no-action text-button font-3 fw-6">
                                <span class="text" data-splitting>Portfolio</span>
                                <span class="text" data-splitting>Portfolio</span>
                            </a>
                        </li>
                        <li class="text-menu text_white">
                            <a href="/#pricing"
                                class="nav_link toggle splitting link link-no-action text-button font-3 fw-6">
                                <span class="text" data-splitting>Pricing</span>
                                <span class="text" data-splitting>Pricing</span>
                            </a>
                        </li>
                        <li class="text-menu text_white">
                            <a href="/blog"
                                class="nav_link toggle splitting link link-no-action text-button font-3 fw-6">
                                <span class="text" data-splitting>Blog</span>
                                <span class="text" data-splitting>Blog</span>
                            </a>
                        </li>
                        <li class="text-menu text_white">
                            <a href="/#contact"
                                class="nav_link toggle splitting link link-no-action text-button font-3 fw-6">
                                <span class="text" data-splitting>Contact</span>
                                <span class="text" data-splitting>Contact</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- main-content -->
        <div class="wrap-main-content">
            <div class="tf-container">
                <!-- user-bar -->
                
                <!-- End user-bar -->

                <div class="row ">
                    <div class="blog-main-content offset-xxl-4 col-xxl-7 offset-xl-4 col-xl-7 ">

                        <div class="main-content section-onepage">
                            <!-- HERO -->
                            <section class="blog-hero">
                              <div class="blog-hero-left">
                                <h1>Blog & <span style="color:#45E77B">Insights</span></h1>
                                <p>WordPress, PHP, Shopify tips and web development guides from real project experience.</p>
                              </div>
                              <div class="blog-hero-right">
                                {Array.from({length: 16}).map((_, i) => <span></span>)}
                              </div>
                            </section>

                            <!-- BLOG GRID -->
                            <section class="blog-grid-section">
                              <div class="blog-grid">
                                {posts.map((post, index) => (
                                  <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="blog-card">
                                    <div class="card-top">
                                      {/* <span class="part-badge">Part {index + 1}</span> */}
                                      <span class="part-badge">{post.data.category}</span>
                                    </div>
                                    <div class="card-body">
                                      <h2>{post.data.title}</h2>
                                      <div class="card-meta">
                                        {new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })} · {post.data.category}
                                      </div>
                                    </div>
                                    <div class="card-img-wrap">
                                      {post.data.featuredImage
                                        ? <img src={post.data.featuredImage} alt={post.data.title} />
                                        : <div class="card-img-placeholder">📝</div>
                                      }
                                    </div>
                                  </a>
                                ))}
                              </div>
                            </section>
                        </div>
                        <!-- End main-content -->

                        <!-- footer-logo -->
                        <div class="footer-logo footer-container text-center ">
                            <img src="/images/logo/footer-logo.png" class="" width="755" height="295" alt="footer">
                        </div>
                        <!-- End footer-logo  -->


                    </div>

                </div>

                <!-- right-bar -->
                <div class="right-bar d-flex flex-column align-items-center">
                    <div class="nav-right area-effect md-hide">
                        <ul class="nav-menu list-icon d-flex flex-column">
                            <li>
                                <a class="nav_link" href="/#about">
                                    <i class="icon icon-User"></i>
                                    <span class="tooltip text-caption-1">About</span>
                                </a>
                            </li>
                            <li>
                                <a class="nav_link" href="/#resume">
                                    <i class="icon icon-ReadCvLogo"></i>
                                    <span class="tooltip text-caption-1">Resume</span>
                                </a>
                            </li>
                            <li>
                                <a class="nav_link" href="/#services">
                                    <i class="icon icon-GearFine"></i>
                                    <span class="tooltip text-caption-1">Services</span>
                                </a>
                            </li>
                            <li>
                                <a class="nav_link" href="/#portfolio">
                                    <i class="icon icon-Briefcase"></i>
                                    <span class="tooltip text-caption-1">Portfolio</span>
                                </a>
                            </li>
                            <li>
                                <a class="nav_link" href="/#pricing">
                                    <i class="icon icon-Tag"></i>
                                    <span class="tooltip text-caption-1">Pricing</span>
                                </a>
                            </li>
                            <li>
                                <a class="nav_link active" href="/blog">
                                    <i class="icon icon-Notebook"></i>
                                    <span class="tooltip text-caption-1">Blog</span>
                                </a>
                            </li>
                            <li>
                                <a class="nav_link" href="/#contact">
                                    <i class="icon icon-PaperPlaneTilt"></i>
                                    <span class="tooltip text-caption-1">Contact</span>
                                </a>
                            </li>
                        </ul>
                        <div class="wrap">
                            <div class="item-shape spotlight">
                                <img src="/images/item/small-comet.png" alt="item">
                            </div>
                        </div>
                    </div>
                </div>
                <!-- End right-bar  -->

            </div>
        </div>
        <!-- /main-content -->

    </div>
    <!-- /wrapper -->

    <div class="overlay-popup"></div>

    <!-- Javascript -->
    <script is:inline src="/js/bootstrap.min.js"></script>
    <script is:inline src="/js/jquery.min.js"></script>
    <script is:inline src="/js/ScrollTrigger.min.js"></script>
    <script is:inline src="/js/SplitText.min.js"></script>
    <script is:inline src="/js/gsap.min.js"></script>
    <script is:inline src="/js/handleGsap.js"></script>
    <script is:inline src="/js/odometer.min.js"></script>
    <script is:inline src="/js/counter.js"></script>
    <script is:inline src="/js/swiper-bundle.min.js"></script>
    <script is:inline src="/js/carousel.js"></script>
    <script is:inline src="/js/textanimation.js"></script>
    <script is:inline src="/js/ScrollSmooth.js"></script>
    <script is:inline src="/js/jquery.fancybox.js"></script>
    <script is:inline src="/js/splitting.min.js"></script>
    <script is:inline src="/js/main.js"></script>
	<script is:inline src="/js/fromsubmit.js"></script>
    <!-- /Javascript -->

</body>

</html>